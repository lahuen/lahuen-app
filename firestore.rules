rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Temporary hardcoded fallback until usuarios collection is seeded
    function isTeamMemberLegacy() {
      return request.auth != null &&
             request.auth.token.email in [
               'cbd.preparados@gmail.com',
               'gmedina86@gmail.com',
               'fefox911@gmail.com',
               'lahuencoop@gmail.com',
               'rodrigocbdthc@gmail.com',
               'walter.medina.pourcel@gmail.com'
             ];
    }

    function isTeamMember() {
      return request.auth != null && (
        exists(/databases/$(database)/documents/usuarios/$(request.auth.token.email))
        || isTeamMemberLegacy()
      );
    }

    function isAdmin() {
      return request.auth != null &&
             exists(/databases/$(database)/documents/usuarios/$(request.auth.token.email)) &&
             get(/databases/$(database)/documents/usuarios/$(request.auth.token.email)).data.role == 'admin';
    }

    // Anyone authenticated can read their own user doc (needed for login check)
    match /usuarios/{email} {
      allow read: if request.auth != null && request.auth.token.email == email;
      allow read, write: if isAdmin();
    }

    match /prospectos/{docId} {
      allow read: if isTeamMember();
      allow create: if isTeamMember()
                    && request.resource.data.createdBy == request.auth.uid;
      allow update: if isTeamMember();
      allow delete: if isTeamMember();
    }

    match /productos/{docId} {
      allow read: if isTeamMember();
      allow create: if isTeamMember()
                    && request.resource.data.createdBy == request.auth.uid;
      allow update: if isTeamMember();
      allow delete: if isTeamMember();
    }

    match /movimientos/{docId} {
      allow read: if isTeamMember();
      allow create: if isTeamMember()
                    && request.resource.data.createdBy == request.auth.uid;
      // Immutable audit trail
      allow update: if false;
      allow delete: if false;
    }

    match /audit_log/{docId} {
      allow read: if isAdmin();
      allow create: if isTeamMember()
                    && request.resource.data.userId == request.auth.uid;
      allow update: if false;
      allow delete: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
